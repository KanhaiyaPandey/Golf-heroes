// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum SubscriptionPlan {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  LAPSED
  PAST_DUE
}

enum DrawType {
  RANDOM
  ALGORITHMIC
}

enum DrawStatus {
  PENDING
  SIMULATION
  PUBLISHED
  COMPLETED
}

enum MatchType {
  FIVE_MATCH
  FOUR_MATCH
  THREE_MATCH
}

enum WinnerVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum UserRole {
  SUBSCRIBER
  ADMIN
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  name              String
  avatarUrl         String?
  role              UserRole @default(SUBSCRIBER)
  hashedPassword    String?
  emailVerified     Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  subscription      Subscription?
  golfScores        GolfScore[]
  charitySelection  CharitySelection?
  drawEntries       DrawEntry[]
  winnerRecords     WinnerRecord[]
  sessions          Session[]

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Subscription {
  id                    String             @id @default(cuid())
  userId                String             @unique
  plan                  SubscriptionPlan
  status                SubscriptionStatus @default(ACTIVE)
  stripeCustomerId      String?            @unique
  stripeSubscriptionId  String?            @unique
  stripePriceId         String?
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean            @default(false)
  monthlyAmountCents    Int                // stored in cents
  charityPercentage     Int                @default(10) // 10-100
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model GolfScore {
  id        String   @id @default(cuid())
  userId    String
  score     Int      // 1-45 Stableford
  playedAt  DateTime @db.Date // date-only, unique per user
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, playedAt])
  @@map("golf_scores")
}

model Charity {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  imageUrl    String?
  websiteUrl  String?
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events            CharityEvent[]
  charitySelections CharitySelection[]
  donations         Donation[]

  @@map("charities")
}

model CharityEvent {
  id          String   @id @default(cuid())
  charityId   String
  title       String
  description String?  @db.Text
  eventDate   DateTime
  location    String?
  imageUrl    String?
  createdAt   DateTime @default(now())

  charity Charity @relation(fields: [charityId], references: [id], onDelete: Cascade)

  @@map("charity_events")
}

model CharitySelection {
  id                String   @id @default(cuid())
  userId            String   @unique
  charityId         String
  customPercentage  Int      @default(10) // override subscription default
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  charity Charity @relation(fields: [charityId], references: [id])

  @@map("charity_selections")
}

model Donation {
  id              String        @id @default(cuid())
  charityId       String
  userId          String?
  amountCents     Int
  isIndependent   Boolean       @default(false)
  stripePaymentId String?
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now())

  charity Charity @relation(fields: [charityId], references: [id])

  @@map("donations")
}

model Draw {
  id              String     @id @default(cuid())
  month           Int        // 1-12
  year            Int
  drawType        DrawType   @default(RANDOM)
  status          DrawStatus @default(PENDING)
  drawnNumbers    Int[]      // 5 numbers drawn
  totalPoolCents  Int        @default(0)
  fiveMatchPool   Int        @default(0) // cents
  fourMatchPool   Int        @default(0) // cents
  threeMatchPool  Int        @default(0) // cents
  jackpotRollover Int        @default(0) // cents carried from prev month
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  entries      DrawEntry[]
  winnerRecords WinnerRecord[]

  @@unique([month, year])
  @@map("draws")
}

model DrawEntry {
  id          String   @id @default(cuid())
  drawId      String
  userId      String
  numbers     Int[]    // user's 5 most recent scores at time of entry
  matchType   MatchType?
  matchCount  Int       @default(0)
  createdAt   DateTime  @default(now())

  draw Draw @relation(fields: [drawId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([drawId, userId])
  @@map("draw_entries")
}

model WinnerRecord {
  id                   String                   @id @default(cuid())
  drawId               String
  userId               String
  matchType            MatchType
  prizeAmountCents     Int
  verificationStatus   WinnerVerificationStatus @default(PENDING)
  proofUrl             String?
  paymentStatus        PaymentStatus            @default(PENDING)
  adminNote            String?
  paidAt               DateTime?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  draw Draw @relation(fields: [drawId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@map("winner_records")
}

model PrizePool {
  id                  String   @id @default(cuid())
  drawId              String   @unique
  totalCents          Int
  fiveMatchCents      Int
  fourMatchCents      Int
  threeMatchCents     Int
  jackpotRollover     Int      @default(0)
  subscriberCount     Int
  calculatedAt        DateTime @default(now())

  @@map("prize_pools")
}
